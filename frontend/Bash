# 1. 安裝 Firebase CLI 工具
npm install -g firebase-tools

# 2. 登入 Firebase 帳戶
firebase login

# 3. 手動建立專案：到網站建立專案（不能用 CLI 建）
# 🔗 https://console.firebase.google.com
# 建立專案名稱：baccarat-predictor-2025

# 4. 進入你的專案資料夾
cd my-baccarat-app

# 5. 初始化 Firebase 設定，並選擇：
# ✅ Firestore
# ✅ Hosting
firebase init

# 6. 建立 React 專案的 build 資料夾（準備部署）
npm run build

# 7. 將網站部署上 Firebase Hosting
firebase deploy